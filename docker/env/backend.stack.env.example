# -----------------------------------------------------------------------------
# Sablon → másolat a compose számára:
#   cp docker/env/backend.stack.env.example docker/env/backend.stack.env
# Magyarázat változókonként: backend/.env.example
# -----------------------------------------------------------------------------

DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=celkereszt
DB_PASSWORD=password
DB_DATABASE=celkereszt

REDIS_HOST=redis
REDIS_PORT=6379

PORT=3000
NODE_ENV=development
APP_TIMEZONE=Europe/Budapest

# Stack web UI: http://localhost:8080
CORS_ORIGIN=http://localhost:8080

JWT_SECRET=change-me-local-only
JWT_EXPIRES_IN=7d

# FIREBASE_PRIVATE_KEY: PEM idézőjelben, több sor → \n (lásd docs/FIREBASE_SETUP.md)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# MOBILE_ENROLLMENT_SECRET=
# PUBLIC_API_BASE_URL=

RECENT_DEVICE_PAIR_IDS_CACHE_MS=400
