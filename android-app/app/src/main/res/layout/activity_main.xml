<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="24dp">

    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Most Wanted"
        android:textColor="#FF6B35"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/pairInfoTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pár #1"
        android:textColor="#888888"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@+id/titleTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/runtimeStatusTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Játékállapot betöltése…"
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@+id/pairInfoTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/messageTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Most Wanted - A hajsza"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:padding="24dp"
        android:gravity="center"
        android:background="#222222"
        android:minHeight="200dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintTop_toBottomOf="@+id/runtimeStatusTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/helpButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Segítség kérése"
        android:textColor="#FFFFFF"
        android:background="#FF6B35"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@+id/messageTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/vehicleButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Jármű START"
        android:textColor="#FFFFFF"
        android:background="#4CAF50"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@+id/helpButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/logoutButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Kijelentkezés"
        android:textColor="#FFFFFF"
        android:background="#F44336"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@+id/vehicleButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>






