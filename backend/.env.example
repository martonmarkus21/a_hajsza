# -----------------------------------------------------------------------------
# Most Wanted — backend (.env sablon)
# Másold `backend` mappában `.env` névre, töltsd ki az értékeket.
# A Nest alkalmazás induláskor ezt a fájlt olvassa (ConfigModule: envFilePath .env).
# -----------------------------------------------------------------------------

# --- PostgreSQL ---
# Párok, eszközök, pozíció előzmények, játékbeállítások, audit napló, stb.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=most_wanted
DB_PASSWORD=password
DB_DATABASE=most_wanted

# --- Redis ---
# Élő GPS pozíciók cache + Bull (háttérfeladatok) ugyanazon a Redis példányon.
REDIS_HOST=localhost
REDIS_PORT=6379

# --- HTTP szerver ---
PORT=3000
# development: TypeORM synchronize bekapcsolva (séma illesztés fejlesztéshez).
# production: állíts production-re éles környezetben.
NODE_ENV=development

# --- CORS ---
# A webes üldöző felület (admin / térkép) URL-je; erről érkezhetnek API + cookie kérések.
CORS_ORIGIN=http://localhost:3001

# --- JWT ---
# Webes és eszköz tokenek aláírása. Élesben erős, véletlenszerű titkot használj.
JWT_SECRET=your-secret-key
# Lejárat (pl. 7d, 24h); lásd @nestjs/jwt dokumentáció.
JWT_EXPIRES_IN=7d

# --- Firebase Cloud Messaging (Android push) ---
# Ha bármelyik hiányzik, az FCM kikapcsolódik (az API ettől még futhat).
# A private key gyakran többsoros: .env-ben idézőjelben, sortörések \n formában.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# --- Opcionális: belső gyorsítótár (milliszekundum) ---
# A backend időnként lekérdezi: mely párok ID-ja tartozik olyan eszközhöz, amelynek lastSeen-je
# az elmúlt 30 percben volt (játékidőzítő / „minden aktív pár küldött már pozíciót?” logika).
# Ez a változó azt mondja meg, hány ms-ig tárolja a szerver e listát a memóriában ugyanazzal
# a tartalommal, hogy ne kelljen minden egyes hívásnál újra SQL-t futtatni. 0 = nincs cache.
RECENT_DEVICE_PAIR_IDS_CACHE_MS=400

# --- Opcionális: naplózás ---
# TypeORM SQL a konzolra: üres/false = kikapcsolva; true|all = minden; error = csak hibák.
# TYPEORM_LOGGING=false
# Részletes alkalmazáslog (pozíció, WebSocket, FCM, eszköz auth). Alapértelmezés: kikapcsolva.
# LOG_VERBOSE=true

# --- Opcionális: adatbázis seed (csak fejlesztés) ---
# Csak NODE_ENV=development mellett fut; élesben SEED_DB=true figyelmen kívül marad (figyelmeztető log).
# Admin/officer felhasználók létrehozása, ha még nincsenek.
# SEED_DB=true
# true: plusz 12 tesztpár (assignedNumber 1–12), csak a seed folyamat részeként.
# SEED_PAIRS=true
