# -----------------------------------------------------------------------------
# Célkereszt — backend (.env sablon)
# Másold `backend` mappában `.env` névre, töltsd ki az értékeket.
# A Nest alkalmazás induláskor ezt a fájlt olvassa (ConfigModule: envFilePath .env).
# Ha nincsen admin felhasználó az indulásnál: automatikusan létrejön admin / admin123.
# -----------------------------------------------------------------------------

# --- PostgreSQL ---
# Párok, eszközök, pozíció előzmények, játékbeállítások, audit napló, stb.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=celkereszt
DB_PASSWORD=password
DB_DATABASE=celkereszt

# --- Redis ---
# Élő GPS pozíciók cache + Bull (háttérfeladatok) ugyanazon a Redis példányon.
REDIS_HOST=localhost
REDIS_PORT=6379

# --- HTTP szerver ---
PORT=3000
# development: TypeORM automatikusan illeszti a Postgres sémát a kódhoz (synchronize).
# production: állítsd production-re éleshez / késztelepítéshez (synchronize kikapcsolva).
NODE_ENV=development

# Játéknap / cron faliórája (HH:mm és naptári „ma”).
# UTC-s Docker példányon állítsd pl. Europe/Budapest-re, hogy a zárórával pont egyezzen a push.
APP_TIMEZONE=Europe/Budapest

# --- CORS ---
# A webes üldöző felület (admin / térkép) URL-je; erről érkezhetnek API + cookie kérések.
CORS_ORIGIN=http://localhost:3001

# --- Mobil (Android) kapcsolódás ---
# Alapból a titok az adatbázisban generálódik (admin → Eszközök → Android kapcsolat), nem kell kézzel kulcsot írni.
# Ha kitöltöd ezt a sort, a .env-beli érték felülírja az adatbázist, és az admin „új titok” gombja nem használható.
# MOBILE_ENROLLMENT_SECRET=
# A QR és az admin felületen megjelenő API alap URL (perjel a végén). Ha üres, a kérés Host fejlécéből
# és X-Forwarded-* proxy fejlécekből próbáljuk kitalálni (reverse proxy mögött állítsd be inkább explicit).
# PUBLIC_API_BASE_URL=https://api.example.com/

# --- JWT ---
# Webes és eszköz tokenek aláírása. Élesben erős, véletlenszerű titkot használj.
JWT_SECRET=your-secret-key
# Lejárat (pl. 7d, 24h); lásd @nestjs/jwt dokumentáció.
JWT_EXPIRES_IN=7d

# --- Firebase Cloud Messaging (Android push) ---
# Kötelező a mobil push és a felhasználói rendszer cél szerinti használatához; Androidhoz plusz kell google-services.json.
# Ha bármelyik FIREBASE_* hiányzik vagy sablonmarad, a backend elindul, de FCM nem működik.
# A private key többsoros: .env-ben idézőjelben, sorvégek \n formában.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# --- Opcionális: belső gyorsítótár (milliszekundum) ---
# A backend időnként lekérdezi: mely párok ID-ja tartozik olyan eszközhöz, amelynek lastSeen-je
# az elmúlt 30 percben volt (játékidőzítő / „minden aktív pár küldött már pozíciót?” logika).
# Ez a változó azt mondja meg, hány ms-ig tárolja a szerver e listát a memóriában ugyanazzal
# a tartalommal, hogy ne kelljen minden egyes hívásnál újra SQL-t futtatni. 0 = nincs cache.
RECENT_DEVICE_PAIR_IDS_CACHE_MS=400

# --- Opcionális: naplózás ---
# TypeORM SQL a konzolra: üres/false = kikapcsolva; true|all = minden; error = csak hibák.
# TYPEORM_LOGGING=false
# Részletes alkalmazáslog (WebSocket, FCM, eszköz auth — nem ír pozíciót). Alapértelmezés: kikapcsolva.
# LOG_VERBOSE=true
# Pozíció / createPosition részletek (külön kapcsoló; LOG_VERBOSE önmagában nem elég). Alapértelmezés: kikapcsolva.
# LOG_VERBOSE_POSITION=true

# --- Opcionális: adatbázis seed (csak fejlesztés) ---
# Csak NODE_ENV=development mellett fut; élesben SEED_DB=true figyelmen kívül marad (figyelmeztető log).
# Extra officer felhasználók + opcionálisan tesztpárok; admint a szerver induláskor külön hozza létre, seed nem kell hozzá.
# SEED_DB=true
# true: plusz 12 tesztpár (assignedNumber 1–12), csak a seed folyamat részeként.
# SEED_PAIRS=true
